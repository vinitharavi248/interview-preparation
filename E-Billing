package System;

import java.util.*;

class Customer {
    int id;
    String name;
    String connectionType;
    int units;
    double billAmount;

    Customer(int id, String name, String connectionType, int units) {
        this.id = id;
        this.name = name;
        this.connectionType = connectionType;
        this.units = units;
    }
}


class BillingService {

    public double calculateBill(int units, String type) {
        double amount = 0;

        if (type.equalsIgnoreCase("Domestic")) {
            if (units <= 100) amount = units * 1.5;
            else if (units <= 300) amount = units * 2.5;
            else amount = units * 4;
        } else { // Commercial
            if (units <= 100) amount = units * 2;
            else if (units <= 300) amount = units * 3.5;
            else amount = units * 5;
        }

        return amount;
    }
}


public class ElectricityBillingSystem {

    static Scanner sc = new Scanner(System.in);
    static List<Customer> customers = new ArrayList<>();
    static BillingService service = new BillingService();
    static int idCounter = 1;

    public static void main(String[] args) {

        int choice;

        do {
            System.out.println("\n===== ELECTRICITY BILLING SYSTEM =====");
            System.out.println("1. Add Customer");
            System.out.println("2. View All Bills");
            System.out.println("3. Search Customer by ID");
            System.out.println("4. Exit");
            System.out.print("Enter your choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    addCustomer();
                    break;
                case 2:
                    viewAllBills();
                    break;
                case 3:
                    searchCustomer();
                    break;
                case 4:
                    System.out.println("Thank you!");
                    break;
                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 4);
    }

    static void addCustomer() {
        sc.nextLine(); // clear buffer

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Connection Type (Domestic/Commercial): ");
        String type = sc.nextLine();

        System.out.print("Enter Units Consumed: ");
        int units = sc.nextInt();

        Customer c = new Customer(idCounter++, name, type, units);


        double bill = service.calculateBill(units, type);
        c.billAmount = bill;

        customers.add(c);

        System.out.println("Customer added successfully!");
        System.out.println("Generated Bill: ₹" + bill);
    }


    static void viewAllBills() {
        if (customers.isEmpty()) {
            System.out.println("No records found!");
            return;
        }

        System.out.println("\n--- ALL CUSTOMER BILLS ---");

        for (Customer c : customers) {
            System.out.println("ID: " + c.id);
            System.out.println("Name: " + c.name);
            System.out.println("Type: " + c.connectionType);
            System.out.println("Units: " + c.units);
            System.out.println("Bill: ₹" + c.billAmount);
            System.out.println("---------------------------");
        }
    }

    static void searchCustomer() {
        System.out.print("Enter Customer ID: ");
        int id = sc.nextInt();

        for (Customer c : customers) {
            if (c.id == id) {
                System.out.println("\n--- CUSTOMER DETAILS ---");
                System.out.println("Name: " + c.name);
                System.out.println("Type: " + c.connectionType);
                System.out.println("Units: " + c.units);
                System.out.println("Bill: ₹" + c.billAmount);
                return;
            }
        }

        System.out.println("Customer not found!");
    }
}
